{
  "expo": {
    "name": "Kindred",
    "slug": "kindred",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "kindred",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A9E8F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nz.kindred.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kindred needs your camera to take photos for listings and ID verification."
      }
    },
    "android": {
      "package": "nz.kindred.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1A9E8F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/68be1a41-902e-40b4-83b2-419cafe2d7b2"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kindred needs your location to find nearby listings and community resources."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kindred needs access to your photos to add images to listings.",
          "cameraPermission": "Kindred needs your camera to take photos for listings and ID verification."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68be1a41-902e-40b4-83b2-419cafe2d7b2"
      }
    },
    "owner": "heremaia"
  }
}
